/*
 * SoC-side board fixups for zc706 (Zynq-7000), layered on top of the
 * gen-machineconf / lopper-generated Linux device tree (which already carries
 * the PS config and the design's PL hardware from the XSA). Scoped to the Linux
 * domain by device-tree.bbappend. Ported from the Ethernet FMC Zynq GEM PetaLinux BSP.
 */

/* 2025.01 u-boot data-aborts probing gem0 because pcw.dtsi does not populate
 * phy-handle. This design's Ethernet FMC test uses the PL AXI Ethernet cores
 * (ports-0123-axieth overlay), not PS GEM, so disabling gem0 avoids the crash. */
&gem0 {
    status = "disabled";
};
