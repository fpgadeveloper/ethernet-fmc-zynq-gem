/*
 * Ethernet FMC Zynq GEM port config: ports-012-.
 *
 * Per-port external-PHY wiring (MAC address, phy-handle, MDIO bus, phy-mode)
 * layered on the SDT-generated Linux device tree. Selected per target by
 * Yocto/scripts/configure-build.sh from the target's lane-derived port config.
 */

&gem0 {
        local-mac-address = [00 0a 35 00 01 22];
        phy-handle = <&extphy0>;
        status = "okay";
        xlnx,has-mdio = <0x1>;
        psu_ethernet_0_mdio: mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy0: phy@0 {
                        device_type = "ethernet-phy";
                        reg = <0>;
                };
                gmii_to_rgmii_0: gmii_to_rgmii_0@8 {
                        phy-handle = <&extphy0>;
                        reg = <8>;
                };
        };
    };  
      
    &gem1 {
        local-mac-address = [00 0a 35 00 01 23];
        phy-handle = <&extphy1>;
        status = "okay";
        xlnx,has-mdio = <0x1>;
        psu_ethernet_1_mdio: mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy1: phy@0 {
                        device_type = "ethernet-phy";
                        reg = <0>;
                };
                gmii_to_rgmii_1: gmii_to_rgmii_1@8 {
                        phy-handle = <&extphy1>;
                        reg = <8>;
                };
        };
    };  
      
    &gem2 {
        local-mac-address = [00 0a 35 00 01 24];
        phy-handle = <&extphy2>;
        status = "okay";
        xlnx,has-mdio = <0x1>;
        psu_ethernet_2_mdio: mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy2: phy@0 {
                        device_type = "ethernet-phy";
                        reg = <0>;
                };
                gmii_to_rgmii_2: gmii_to_rgmii_2@8 {
                        phy-handle = <&extphy2>;
                        reg = <8>;
                };
        };
    };  
    
    /* GEM3 may be connected to the on-board Ethernet port via MIO */

    &gem3 {
        local-mac-address = [00 0a 35 00 01 25];
        phy-handle = <&extphy3>;
        phy-mode = "rgmii-id";
        status = "okay";
        xlnx,ptp-enet-clock = <0x69f6bcb>;
        xlnx,has-mdio = <0x1>;
        psu_ethernet_3_mdio: mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy3: phy@0x0c {
                        reg = <0x0c>;
                        ti,rx-internal-delay = <0x8>;
                        ti,tx-internal-delay = <0xa>;
                        ti,fifo-depth = <0x1>;
                };
        };
    };  
      
