/*
 * Ethernet FMC Zynq GEM port config: ports-0123-axieth.
 *
 * Per-port external-PHY wiring (MAC address, phy-handle, MDIO bus, phy-mode)
 * layered on the SDT-generated Linux device tree. Selected per target by
 * Yocto/scripts/configure-build.sh from the target's lane-derived port config.
 */

&axi_ethernet_0 {  
    	/delete-property/ xlnx,phy-type;
        local-mac-address = [00 0a 35 00 01 22];  
        phy-handle = <&extphy0>;  
        xlnx,has-mdio = <0x1>;  
        phy-mode = "rgmii-rxid";  
        mdio {  
            #address-cells = <1>;  
            #size-cells = <0>;  
            extphy0: phy@0 {  
                device_type = "ethernet-phy";  
                reg = <0>;  
            };  
        };  
    };  
      
    &axi_ethernet_1 {  
    	/delete-property/ xlnx,phy-type;
        local-mac-address = [00 0a 35 00 01 23];  
        phy-handle = <&extphy1>;  
        xlnx,has-mdio = <0x1>;  
        phy-mode = "rgmii-rxid";  
        mdio {  
            #address-cells = <1>;  
            #size-cells = <0>;  
            extphy1: phy@0 {  
                device_type = "ethernet-phy";  
                reg = <0>;  
            };  
        };  
    };  
      
    &axi_ethernet_2 {  
    	/delete-property/ xlnx,phy-type;
        local-mac-address = [00 0a 35 00 01 24];  
        phy-handle = <&extphy2>;  
        xlnx,has-mdio = <0x1>;  
        phy-mode = "rgmii-rxid";  
        mdio {  
            #address-cells = <1>;  
            #size-cells = <0>;  
            extphy2: phy@0 {  
                device_type = "ethernet-phy";  
                reg = <0>;  
            };  
        };  
    };  
      
    &gem0 {
        local-mac-address = [00 0a 35 00 01 26];
        phy-handle = <&extphy4>;
        phy-mode = "rgmii-id";
        status = "okay";
        xlnx,ptp-enet-clock = <0x69f6bcb>;
        xlnx,has-mdio = <0x1>;
        mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy4: phy@0 {
                        device_type = "ethernet-phy";
                        reg = <0>;
                };
        };
    };  
      
    &gem1 {
        local-mac-address = [00 0a 35 00 01 25];
        phy-handle = <&extphy3>;
        status = "okay";
        xlnx,has-mdio = <0x1>;
        mdio {
                #address-cells = <1>;
                #size-cells = <0>;
                extphy3: phy@0 {
                        device_type = "ethernet-phy";
                        reg = <0>;
                };
                gmii_to_rgmii_0: gmii_to_rgmii_0@8 {
                        phy-handle = <&extphy3>;
                        reg = <8>;
                };
        };
    };  
      
