/*
 * SoC-side board fixups for pz (Zynq-7000), layered on top of the
 * gen-machineconf / lopper-generated Linux device tree (which already carries
 * the PS config and the design's PL hardware from the XSA). Scoped to the Linux
 * domain by device-tree.bbappend. Ported from the Ethernet FMC Zynq GEM PetaLinux BSP.
 */

/ {

   xlnk {
      compatible = "xlnx,xlnk-1.0";
   };

};

/* QSPI partitions are defined with petalinux-config and described in system.conf.dtsi */
&qspi {
   #address-cells = <1>;
   #size-cells = <0>;
   status = "okay";
   is-dual = <0>;
   num-cs = <1>;
   flash0: flash@0 {
      compatible = "n25q128a11";
      reg = <0x0>;
      spi-tx-bus-width = <1>;
      spi-rx-bus-width = <4>;
      spi-max-frequency = <50000000>;      
      #address-cells = <1>;
      #size-cells = <1>;
   };
};

/ {
    usb_phy0:usb_phy@0 {
        compatible="usb-nop-xceiv";
        #phy-cells = <0>;
    };
};


&usb0 {
    dr_mode = "otg";
    usb-phy = <&usb0>;
};


/* 2025.01 u-boot data-aborts probing gem0 because pcw.dtsi does not populate
 * phy-handle. This design's Ethernet FMC test uses the PL AXI Ethernet cores
 * (ports-0123-axieth overlay), not PS GEM, so disabling gem0 avoids the crash. */
&gem0 {
    status = "disabled";
};
